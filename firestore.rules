rules_version = '2';

// Base partagée : seul le compte commun (email/mot de passe créé dans
// Authentication → Users de la console Firebase) peut lire et écrire.
// À publier dans la console : Firestore Database → Règles,
// après avoir remplacé l'email ci-dessous.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null
        && request.auth.token.email == 'alexis.telliez62@gmail.com';
    }
  }
}
